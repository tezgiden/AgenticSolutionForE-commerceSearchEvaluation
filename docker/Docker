# Dockerfile for LLM Search Result Evaluation System
# Multi-stage build for optimized production image

# Build stage
FROM python:3.11-slim AS builder

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Create virtual environment
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy requirements and install Python dependencies
COPY requirements.txt .
RUN pip install --upgrade pip setuptools wheel && \
    pip install -r requirements.txt

# Copy source code
COPY . /app
WORKDIR /app

# Install the package
RUN pip install -e .

# Production stage
FROM python:3.11-slim AS production

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/opt/venv/bin:$PATH" \
    ENVIRONMENT=production

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy virtual environment from builder stage
COPY --from=builder /opt/venv /opt/venv

# Copy application code
COPY --from=builder /app /app
WORKDIR /app

# Create non-root user
RUN groupadd -r llmeval && useradd -r -g llmeval llmeval

# Create directories and set permissions
RUN mkdir -p /app/logs /app/data /app/config && \
    chown -R llmeval:llmeval /app

# Switch to non-root user
USER llmeval

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "from llm_evaluator import ValidationUtils, LLMConfig; \
                   config = LLMConfig.from_environment(); \
                   result = ValidationUtils.validate_service_connectivity(config); \
                   exit(0 if result['available'] else 1)"

# Expose port (if needed for future API)
EXPOSE 8000

# Default command
CMD ["python", "-m", "llm_evaluator.cli", "status"]

# Development stage
FROM production AS development

# Switch back to root for development tools
USER root

# Install development dependencies
RUN pip install pytest pytest-cov black flake8 mypy isort pre-commit

# Install additional development tools
RUN apt-get update && apt-get install -y \
    vim \
    git \
    htop \
    && rm -rf /var/lib/apt/lists/*

# Switch back to llmeval user
USER llmeval

# Set development environment
ENV ENVIRONMENT=development

# Development command
CMD ["python", "-m", "llm_evaluator.cli", "validate"]

# Testing stage
FROM development AS testing

# Copy test files
COPY tests/ /app/tests/

# Set testing environment
ENV ENVIRONMENT=testing

# Run tests by default
CMD ["pytest", "tests/", "-v", "--tb=short"]

---

# docker-compose.yml
version: '3.8'

services:
  # Ollama service for LLM functionality
  ollama:
    image: ollama/ollama:latest
    container_name: ollama
    ports:
      - "11434:11434"
    volumes:
      - ollama_data:/root/.ollama
    environment:
      - OLLAMA_KEEP_ALIVE=24h
    restart: unless-stopped
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: 1
              capabilities: [gpu]
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:11434/api/tags"]
      interval: 30s
      timeout: 10s
      retries: 3

  # LLM Evaluator service
  llm-evaluator:
    build:
      context: .
      target: production
    container_name: llm-evaluator
    depends_on:
      - ollama
    environment:
      - OLLAMA_API_ENDPOINT=http://ollama:11434/api/generate
      - DEFAULT_MODEL=gemma3
      - TIMEOUT=600
      - MAX_RETRIES=3
      - DEBUG_DIR=/app/debug
      - LOG_LEVEL=INFO
      - ENVIRONMENT=production
    volumes:
      - ./data:/app/data
      - ./logs:/app/logs
      - ./debug:/app/debug
      - ./config:/app/config
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "python", "-m", "llm_evaluator.cli", "validate"]
      interval: 60s
      timeout: 30s
      retries: 3

  # Development service
  llm-evaluator-dev:
    build:
      context: .
      target: development
    container_name: llm-evaluator-dev
    depends_on:
      - ollama
    environment:
      - OLLAMA_API_ENDPOINT=http://ollama:11434/api/generate
      - DEFAULT_MODEL=gemma3
      - TIMEOUT=300
      - MAX_RETRIES=2
      - DEBUG_DIR=/app/debug
      - LOG_LEVEL=DEBUG
      - ENVIRONMENT=development
    volumes:
      - .:/app
      - dev_venv:/opt/venv
    ports:
      - "8000:8000"
    command: ["tail", "-f", "/dev/null"]
    profiles:
      - dev

  # Testing service
  llm-evaluator-test:
    build:
      context: .
      target: testing
    container_name: llm-evaluator-test
    depends_on:
      - ollama
    environment:
      - OLLAMA_API_ENDPOINT=http://ollama:11434/api/generate
      - DEFAULT_MODEL=gemma3
      - ENVIRONMENT=testing
    volumes:
      - .:/app
      - test_coverage:/app/coverage
    command: ["pytest", "tests/", "-v", "--cov=llm_evaluator", "--cov-report=html:/app/coverage"]
    profiles:
      - test

  # Redis for caching (optional future enhancement)
  redis:
    image: redis:7-alpine
    container_name: llm-evaluator-redis
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    restart: unless-stopped
    profiles:
      - cache

  # PostgreSQL for storing results (optional future enhancement)
  postgres:
    image: postgres:15-alpine
    container_name: llm-evaluator-postgres
    environment:
      - POSTGRES_DB=llm_evaluator
      - POSTGRES_USER=llmeval
      - POSTGRES_PASSWORD=secure_password_change_me
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./scripts/init.sql:/docker-entrypoint-initdb.d/init.sql
    restart: unless-stopped
    profiles:
      - database

volumes:
  ollama_data:
  dev_venv:
  test_coverage:
  redis_data:
  postgres_data:

networks:
  default:
    name: llm-evaluator-network

