# scripts/docker-setup.sh
#!/bin/bash
# Setup script for Docker development environment

set -e

echo "🐋 Setting up LLM Evaluator Docker environment..."

# Check if Docker is installed
if ! command -v docker &> /dev/null; then
    echo "❌ Docker is not installed. Please install Docker first."
    exit 1
fi

# Check if Docker Compose is installed
if ! command -v docker-compose &> /dev/null; then
    echo "❌ Docker Compose is not installed. Please install Docker Compose first."
    exit 1
fi

# Create necessary directories
mkdir -p logs data debug config

# Build the Docker images
echo "🔨 Building Docker images..."
docker-compose build

# Start Ollama service
echo "🚀 Starting Ollama service..."
docker-compose up -d ollama

# Wait for Ollama to be ready
echo "⏳ Waiting for Ollama to be ready..."
timeout=60
count=0
while ! docker-compose exec -T ollama curl -f http://localhost:11434/api/tags &>/dev/null; do
    if [ $count -ge $timeout ]; then
        echo "❌ Timeout waiting for Ollama to start"
        exit 1
    fi
    sleep 1
    count=$((count + 1))
done

# Pull the default model
echo "📥 Pulling default model (gemma3)..."
docker-compose exec ollama ollama pull gemma3

# Test the evaluator
echo "🧪 Testing the evaluator..."
docker-compose run --rm llm-evaluator python -m llm_evaluator.cli validate

echo "✅ Docker environment setup complete!"
echo ""
echo "Next steps:"
echo "  - Start development environment: docker-compose --profile dev up -d"
echo "  - Run tests: docker-compose --profile test up"
echo "  - View logs: docker-compose logs -f llm-evaluator"
echo "  - Execute CLI commands: docker-compose exec llm-evaluator python -m llm_evaluator.cli --help"

---

# scripts/docker-cleanup.sh
#!/bin/bash
# Cleanup script for Docker environment

set -e

echo "🧹 Cleaning up LLM Evaluator Docker environment..."

# Stop all services
docker-compose --profile dev --profile test --profile cache --profile database down

# Remove volumes (optional - uncomment if you want to remove data)
# docker-compose down -v

# Remove unused images
docker image prune -f

# Remove unused containers
docker container prune -f

echo "✅ Docker cleanup complete!"

---

# Makefile for Docker operations
.PHONY: docker-build docker-up docker-down docker-test docker-dev docker-logs docker-clean

# Docker build
docker-build:
	docker-compose build

# Start production services
docker-up:
	docker-compose up -d

# Stop services
docker-down:
	docker-compose down

# Start development environment
docker-dev:
	docker-compose --profile dev up -d

# Run tests
docker-test:
	docker-compose --profile test up --abort-on-container-exit

# View logs
docker-logs:
	docker-compose logs -f

# Clean up
docker-clean:
	docker-compose --profile dev --profile test down
	docker image prune -f
	docker container prune -f

# Setup environment
docker-setup:
	chmod +x scripts/docker-setup.sh
	./scripts/docker-setup.sh

# Full development setup
docker-dev-setup: docker-build docker-setup docker-dev
	@echo "🎉 Development environment is ready!"

# Production deployment
docker-deploy:
	docker-compose up -d
	docker-compose exec llm-evaluator python -m llm_evaluator.cli validate

# Health check
docker-health:
	docker-compose ps
	docker-compose exec llm-evaluator python -m llm_evaluator.cli status
